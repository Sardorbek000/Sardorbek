rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (request.auth.uid == userId || getUserRole() == 'admin');
      allow update, delete: if isSignedIn() && (request.auth.uid == userId || getUserRole() == 'admin');
    }

    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (getUserRole() == 'teacher' || getUserRole() == 'admin');
      allow update, delete: if isSignedIn() && (getUserRole() == 'admin' || (getUserRole() == 'teacher' && resource.data.teacherId == request.auth.uid));
    }

    match /tests/{testId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (getUserRole() == 'teacher' || getUserRole() == 'admin');
      allow update, delete: if isSignedIn() && (getUserRole() == 'admin' || (getUserRole() == 'teacher' && resource.data.createdBy == request.auth.uid));
      
      match /questions/{questionId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isSignedIn() && (getUserRole() == 'admin' || (getUserRole() == 'teacher' && get(/databases/$(database)/documents/tests/$(testId)).data.createdBy == request.auth.uid));
      }
    }

    match /attempts/{attemptId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || getUserRole() == 'teacher' || getUserRole() == 'admin');
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || getUserRole() == 'teacher' || getUserRole() == 'admin');
      
      match /answers/{answerId} {
        allow read: if isSignedIn() && (get(/databases/$(database)/documents/attempts/$(attemptId)).data.userId == request.auth.uid || getUserRole() == 'teacher' || getUserRole() == 'admin');
        allow create, update: if isSignedIn() && get(/databases/$(database)/documents/attempts/$(attemptId)).data.userId == request.auth.uid;
      }
    }
  }
}